{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TritonAI UX agent finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fingerprint",
    "route",
    "sourceFile",
    "sectionId",
    "currentPattern",
    "recommendedComponent",
    "referenceIds",
    "rationale",
    "confidence",
    "ownership",
    "accessibilityRisks",
    "recipe",
    "disposition"
  ],
  "properties": {
    "fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "route": { "type": "string", "pattern": "^/" },
    "sourceFile": { "type": "string", "pattern": "^(content|src/site)/" },
    "sectionId": { "type": "string", "pattern": "^ux-[a-z0-9-]+$" },
    "currentPattern": { "type": "string", "minLength": 1 },
    "recommendedComponent": { "type": "string", "minLength": 1 },
    "referenceIds": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "rationale": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "ownership": { "enum": ["agent-owned", "structured-content", "shared", "human-owned"] },
    "accessibilityRisks": { "type": "array", "items": { "type": "string" } },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "automatic"],
      "properties": {
        "id": { "type": "string" },
        "automatic": { "type": "boolean" }
      }
    },
    "disposition": { "enum": ["no-change", "report-only", "draft-candidate"] }
  }
}
